# ============================================================
# INSURANCE AGENT OS — DEMO
# Variables de entorno requeridas
# Copia este archivo como .env.local y llena los valores
# ============================================================

# ------------------------------------------------------------
# XORIA — API propia (copiloto operativo transversal)
# ------------------------------------------------------------
ALEON_API_URL=https://api.al-eon.com
SERVICE_TOKEN_ALEON=your_aleon_service_token_here

# ------------------------------------------------------------
# OPENAI — Copiloto principal + voz en tiempo real
# Modelos usados:
#   - gpt-4o           → XORIA chat, razonamiento operativo
#   - gpt-4o-realtime  → Voz en tiempo real
#   - gpt-4o-transcribe → Transcripción de audios
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# ANTHROPIC — Análisis de documentos largos
# Modelo: claude-sonnet-4-6
# Usado para: comparar pólizas, leer condiciones generales,
# análisis de paquetes documentales extensos
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------
# GROQ — Transcripción rápida batch
# Modelo: whisper-large-v3
# Usado para: transcripción masiva de audios no críticos
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------
# DEMO CONFIG — Configuración del modo demo
# ------------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=true      # Activa datos mock en toda la app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Insurance Agent OS

# ------------------------------------------------------------
# NOTAS
# - Auth: simulado (mock users, sin OAuth real en demo)
# - Base de datos: mock data en /src/data/mock/
# - Sin Supabase en el demo
# - Sin Google OAuth / Apple OAuth en el demo
# ------------------------------------------------------------
